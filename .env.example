# ============================================================
# API Pilot 环境配置示例
# 复制为 .env 并按需修改
# ============================================================

# ============================================================
# ⚠️ 生产环境必须配置项
# ============================================================

# ---- 后端配置 ----
API_HOST=0.0.0.0
API_PORT=5000

# ---- 数据库配置 ----
# SQLite 数据库（轻量级，适合中小型项目）
# 注意：SQLite 不支持多进程，uvicorn workers 必须为 1
# 生产环境建议使用 PostgreSQL
DATABASE_URL=sqlite+aiosqlite:///backend/data/api_pilot.db
# PostgreSQL 示例：postgresql+asyncpg://user:password@localhost:5432/api_pilot

# ---- JWT 密钥 ----
# ⚠️ 严重警告：生产环境必须设置至少 32 字符的随机字符串
# 开发环境：空密钥会自动生成并写入 .secret_key 文件（仅适用于单机开发）
# 生产环境：服务将拒绝启动如果密钥不足 32 字符
# 生成方式: python -c "import secrets; print(secrets.token_urlsafe(48))"
API_PILOT_SECRET_KEY=

# ---- CORS 配置 ----
# ⚠️ 严重警告：生产环境禁止使用 "*"
# 正确示例：https://app.example.com,https://admin.example.com
# 如果不确定，使用 ENFORCE_CORS_WHITELIST=true 强制白名单模式
CORS_ORIGINS=https://your-domain.com
ENFORCE_CORS_WHITELIST=true

# ---- 运行环境 ----
# development: 开发环境（自动创建表、启用调试路由）
# production: 生产环境（强制安全检查、禁用调试路由）
ENVIRONMENT=production

# ---- 电商 Mock 服务 ----
# 开发环境默认开启，生产环境建议关闭
MOCK_ECOMMERCE_ENABLED=false

# ---- 高风险运维接口 ----
# 种子重置/迁移等危险操作，生产环境必须为 false
ENABLE_DANGEROUS_SEED_ENDPOINTS=false

# ============================================================
# 可选配置项
# ============================================================

# ---- Cloudflare Turnstile ----
# 获取地址: https://dash.cloudflare.com/
# 开发环境使用测试密钥，生产环境必须使用真实密钥
TURNSTILE_SECRET_KEY=your-turnstile-secret-key
# 生产环境强制验证
# ENFORCE_TURNSTILE_PRODUCTION=true

# ---- 报告清理 ----
# 测试报告保留天数
REPORT_RETENTION_DAYS=30

# ---- 种子数据 ----
# ⚠️ 上线前必须修改默认密码
# 生成强密码: python -c "import secrets; print(secrets.token_urlsafe(16))"
SEED_ADMIN_PASSWORD=change-this-password-admin
SEED_DEMO_PASSWORD=change-this-password-demo
SEED_TESTER_PASSWORD=change-this-password-tester

# ---- 限流配置 ----
RATE_LIMIT_LOGIN=20/minute
RATE_LIMIT_REGISTER=10/minute
RATE_LIMIT_REFRESH=60/minute

# ---- 受信反向代理 ----
# 逗号分隔的代理 IP/CIDR。为空时不信任 X-Forwarded-For 头（始终使用直连 IP）。
# 示例: TRUSTED_PROXIES=10.0.0.1,172.16.0.0/12
TRUSTED_PROXIES=

# ---- 前端配置 ----
# 生产环境 API 地址（必须与后端一致）
API_BASE_URL=http://localhost:5000
VITE_API_BASE_URL=http://localhost:5000
# 生产环境示例：https://api.your-domain.com
