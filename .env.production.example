# ============================================================
# API Pilot 生产环境配置模板
# 用法: cp .env.production.example .env && chmod 600 .env
# ============================================================
# 警告:
#   1. .env 文件包含敏感凭据，请勿提交到 git
#   2. 所有标有 CHANGE_ME 的值必须在部署前替换
#   3. 任何空密钥配置都会导致 production 模式启动失败
# ============================================================

# ============================================================
# 基础运行环境
# ============================================================
ENVIRONMENT=production

# ============================================================
# 后端服务监听
# ============================================================
# 容器部署用 0.0.0.0；裸机建议 127.0.0.1 + 反向代理
API_HOST=0.0.0.0
API_PORT=5000

# ============================================================
# 安全密钥（生产环境必填，启动时会强校验）
# ============================================================
# ---- JWT 签名密钥 ----
# 至少 32 字符随机字符串；空值 / 不足长度会导致服务拒绝启动
# 生成方式: python -c "import secrets; print(secrets.token_urlsafe(48))"
API_PILOT_SECRET_KEY=

# ---- Fernet 对称加密密钥（用于敏感变量加密） ----
# URL-safe base64 编码的 32 字节密钥
# 生成方式: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_ENCRYPTION_KEY=

# ============================================================
# 数据库
# ============================================================
# 推荐使用 PostgreSQL（生产环境支持并发与多 worker）
# 格式: postgresql+asyncpg://<user>:<password>@<host>:<port>/<dbname>
DATABASE_URL=postgresql+asyncpg://api_pilot:CHANGE_ME@localhost:5432/api_pilot

# ============================================================
# CORS 跨域白名单
# ============================================================
# 多个来源用英文逗号分隔
# 不能用 *（生产环境强校验白名单）
CORS_ORIGINS=https://your-domain.com
# 额外保险：强制 CORS 白名单模式（推荐开启）
ENFORCE_CORS_WHITELIST=true

# ============================================================
# 限流配置（slowapi 格式）
# ============================================================
RATE_LIMIT_LOGIN=10/minute
RATE_LIMIT_REGISTER=5/minute
RATE_LIMIT_REFRESH=60/minute

# ============================================================
# Cloudflare Turnstile 人机验证
# ============================================================
# test = 仅开发用测试密钥（不校验）
# production = 强制校验真实密钥
# disabled = 完全关闭
TURNSTILE_MODE=production
# 从 https://dash.cloudflare.com/ 获取，**禁止使用测试密钥**
TURNSTILE_SECRET_KEY=
# 额外保险：启动时强制检查 TURNSTILE_SECRET_KEY 已设置
ENFORCE_TURNSTILE_PRODUCTION=true

# ============================================================
# SSRF 防护 - 出站 HTTP 白名单
# ============================================================
# 逗号分隔的 host / IP / CIDR
# 仅放行受信的外部服务地址，避免被用于探测内网
ALLOWED_API_HOSTS=api.your-domain.com,internal-api.your-domain.com

# ============================================================
# 数据保留 & 运维开关
# ============================================================
# 测试报告保留天数（到期自动清理）
REPORT_RETENTION_DAYS=30

# 危险运维端点（种子重置 / 强制迁移等）开关
# 生产环境必须为 false
ENABLE_DANGEROUS_SEED_ENDPOINTS=false

# 电商 Mock 服务开关
# 生产环境必须为 false
MOCK_ECOMMERCE_ENABLED=false

# ============================================================
# 前端构建期变量（Docker build 时注入到 Vite）
# ============================================================
# 与 CORS_ORIGINS 同源，避免跨域与 cookie 问题
# 反向代理场景：使用 /api（同源走 nginx）
# 直连后端场景：使用 https://api.your-domain.com
VITE_API_BASE_URL=/api

# ============================================================
# 种子数据初始密码（可选；不设置则跳过种子初始化）
# ============================================================
# 至少 16 字符的强随机密码
# 生成方式: python -c "import secrets; print(secrets.token_urlsafe(16))"
SEED_ADMIN_PASSWORD=
SEED_DEMO_PASSWORD=
SEED_TESTER_PASSWORD=
